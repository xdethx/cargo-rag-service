# Copy this file to `.env` and fill in the values. NEVER commit `.env`.
# Model names below are examples — verify the current name in each provider's docs.

# Which LLM provider to use at runtime: anthropic | openai_compatible | ollama | gemini
# For cloud/Groq: LLM_PROVIDER=openai_compatible + OPENAI_COMPAT_* vars below.
# Set to 'ollama' for free, offline local dev (no API key needed).
LLM_PROVIDER=ollama

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6          # or claude-haiku-4-5 for cheaper

# --- OpenAI-compatible: covers Grok (xAI), Groq, OpenRouter ---
# Pick ONE provider and set its base_url + model + key.
#   Grok (xAI):  base_url=https://api.x.ai/v1
#   Groq:        base_url=https://api.groq.com/openai/v1   model=llama-3.3-70b-versatile
#   OpenRouter:  base_url=https://openrouter.ai/api/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_BASE_URL=https://api.groq.com/openai/v1
OPENAI_COMPAT_MODEL=llama-3.3-70b-versatile

# --- Google Gemini (generous free tier) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Ollama (local only, optional) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# --- Embeddings: local + free, no key needed. Same model for ingest and query. ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- Retrieval ---
TOP_K=4

# --- Server ---
PORT=7860   # default matches Hugging Face Docker Space

# --- Auth ---
# Callers must send: Authorization: Bearer <value>
# Fail-closed: if unset, every /ask request returns 401.
# Generate a strong random value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
RAG_API_KEY=
